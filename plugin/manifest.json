{
  "manifest_version": 3,
  "default_locale": "en",
  "name": "__MSG_extensionName__",
  "short_name": "__MSG_extensionShortName__",
  "version": "0.2.1",
  "description": "__MSG_extensionDescription__",
  "permissions": [
    "storage"
  ],
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "host_permissions": [
    "*://teams.microsoft.com/*",
    "*://*.teams.microsoft.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "*://teams.microsoft.com/*",
        "*://*.teams.microsoft.com/*"
      ],
      "js": [
        "content.js"
      ],
      "css": [
        "styles.css"
      ],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "mic.svg"
      ],
      "matches": [
        "*://teams.microsoft.com/*",
        "*://*.teams.microsoft.com/*"
      ]
    }
  ],
  "action": {
    "default_title": "__MSG_actionTitle__",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png"
    }
  }
}